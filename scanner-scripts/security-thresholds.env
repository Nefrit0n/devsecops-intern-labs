# Единый учебный конфиг для локального security pipeline.
#
# Как использовать:
# 1) Можете менять значения прямо в этом файле;
# 2) или переопределять переменными окружения при запуске команды.
#
# Пример (информативный режим для SCA):
# SCA_EXIT_CODE=0 bash scanner-scripts/run_sca_scan.sh .

# -------- SCA (Trivy FS) --------
# Какие уровни уязвимостей считаем значимыми.
: "${SCA_SEVERITY:=HIGH,CRITICAL}"
# 1 = завершать с ошибкой при найденных уязвимостях выбранной severity, 0 = только отчёт.
: "${SCA_EXIT_CODE:=1}"
# true = учитывать только фиксируемые проблемы (проще для учебного triage).
: "${SCA_IGNORE_UNFIXED:=false}"

# -------- Container scan (Trivy Image) --------
: "${CONTAINER_SEVERITY:=HIGH,CRITICAL}"
: "${CONTAINER_EXIT_CODE:=1}"
: "${CONTAINER_IGNORE_UNFIXED:=false}"

# -------- Secret scan (Gitleaks) --------
# 1 = блокировать при найденных секретах, 0 = только предупреждать.
: "${SECRET_EXIT_CODE:=1}"
# Путь к кастомному правилу Gitleaks (опционально).
: "${SECRET_CONFIG:=}"

# -------- SAST (OpenGrep) --------
# Можно оставить "auto" для базового учебного набора или задать путь к ruleset.
: "${OPENGREP_CONFIG:=auto}"
# Совместимость: если осталась старая переменная SAST_CONFIG, используем её как fallback.
: "${OPENGREP_CONFIG:=${SAST_CONFIG:-auto}}"
# true = пайплайн получает non-zero при findings, false = только отчёт.
: "${SAST_FAIL_ON_FINDINGS:=true}"
# Фильтр по severity для OpenGrep (опционально): INFO | WARNING | ERROR.
: "${SAST_SEVERITY:=}"
